---
const year = new Date().getFullYear();
---

<footer class="bg-[#0E0E0E] w-full py-16 px-8 mt-auto border-t border-outline-variant/5">
  <div class="grid grid-cols-2 md:grid-cols-4 gap-12 max-w-[1400px] mx-auto">
    <div class="col-span-2 md:col-span-1">
      <span class="text-xl font-bold text-white font-headline mb-4 block">Hostbox</span>
      <p class="font-label text-xs uppercase tracking-widest text-outline-variant leading-relaxed">
        &copy; {year} Hostbox. Built for the sovereign architect.
      </p>
    </div>
    <div>
      <h4 class="font-label text-xs uppercase tracking-widest text-white mb-6">Product</h4>
      <ul class="space-y-4">
        <li><a class="font-label text-xs uppercase tracking-widest text-outline-variant hover:text-primary transition-colors" href="/features">Features</a></li>
        <li><a class="font-label text-xs uppercase tracking-widest text-outline-variant hover:text-primary transition-colors" href="/cli">CLI</a></li>
        <li><a class="font-label text-xs uppercase tracking-widest text-outline-variant hover:text-primary transition-colors" href="https://github.com/VatsalP117/hostbox/blob/main/docs/SELF-HOSTING.md" target="_blank" rel="noopener noreferrer">Docs</a></li>
      </ul>
    </div>
    <div>
      <h4 class="font-label text-xs uppercase tracking-widest text-white mb-6">Community</h4>
      <ul class="space-y-4">
        <li><a class="font-label text-xs uppercase tracking-widest text-outline-variant hover:text-primary transition-colors" href="https://github.com/VatsalP117/hostbox" target="_blank" rel="noopener noreferrer">GitHub</a></li>
        <li><a class="font-label text-xs uppercase tracking-widest text-outline-variant hover:text-primary transition-colors" href="https://github.com/VatsalP117/hostbox/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">License</a></li>
      </ul>
    </div>
    <div>
      <h4 class="font-label text-xs uppercase tracking-widest text-white mb-6">Legal</h4>
      <ul class="space-y-4">
        <li><a class="font-label text-xs uppercase tracking-widest text-outline-variant hover:text-primary transition-colors" href="https://github.com/VatsalP117/hostbox/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">MIT License</a></li>
      </ul>
    </div>
  </div>
</footer>