# Hostbox Configuration
# Copy this file to .env and edit with your values.

# Platform
PLATFORM_DOMAIN=example.com
# Dashboard host (defaults to hostbox.${PLATFORM_DOMAIN} when empty)
DASHBOARD_DOMAIN=
PLATFORM_HTTPS=true
PLATFORM_NAME=Hostbox

# Authentication (REQUIRED — generate with: openssl rand -hex 32)
JWT_SECRET=
ENCRYPTION_KEY=

# Database
DATABASE_PATH=/opt/hostbox/data/hostbox.db
DEPLOYMENTS_DIR=/opt/hostbox/deployments
LOGS_DIR=/opt/hostbox/logs
CACHE_DIR=/opt/hostbox/cache
BACKUP_DIR=/opt/hostbox/data/backups
CLONE_BASE_DIR=/opt/hostbox/tmp
DEPLOYMENT_BASE_DIR=/opt/hostbox/deployments
LOG_BASE_DIR=/opt/hostbox/logs
# Docker socket group on the host (find with: stat -c '%g' /var/run/docker.sock)
DOCKER_GID=998

# SSL / ACME
ACME_EMAIL=admin@example.com

# DNS Provider (for wildcard SSL — optional)
# DNS_PROVIDER=none
# DNS_PROVIDER=cloudflare
# CF_API_TOKEN=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_HOSTED_ZONE_ID=
# DO_AUTH_TOKEN=

# GitHub App (optional — for git-push deployments)
# GITHUB_APP_ID=
# GITHUB_APP_SLUG=
# GITHUB_APP_PEM=
# GITHUB_WEBHOOK_SECRET=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Build containers (increase for large Node.js workspaces)
# BUILD_MEMORY_MB=1024
# BUILD_CPUS=1.0
# BUILD_PID_LIMIT=256

# SMTP (optional — for email notifications)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@example.com
