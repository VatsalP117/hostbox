# Hostbox Configuration
# Copy this file to .env and edit with your values.

# Platform
PLATFORM_DOMAIN=example.com
DASHBOARD_DOMAIN=hostbox.example.com
PLATFORM_HTTPS=true
PLATFORM_NAME=Hostbox

# Authentication (REQUIRED — generate with: openssl rand -hex 32)
JWT_SECRET=
ENCRYPTION_KEY=

# Database
DATABASE_PATH=/app/data/hostbox.db

# SSL / ACME
ACME_EMAIL=admin@example.com

# DNS Provider (for wildcard SSL — optional)
# DNS_PROVIDER=cloudflare
# CF_API_TOKEN=

# GitHub App (optional — for git-push deployments)
# GITHUB_APP_ID=
# GITHUB_APP_SLUG=
# GITHUB_APP_PEM=
# GITHUB_WEBHOOK_SECRET=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# SMTP (optional — for email notifications)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@example.com
