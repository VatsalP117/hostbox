# Hostbox Configuration
# Copy this file to .env and fill in the values

# Required
PLATFORM_DOMAIN=example.com
# Dashboard host (defaults to hostbox.${PLATFORM_DOMAIN} when empty)
DASHBOARD_DOMAIN=
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Server
HOST=0.0.0.0
PORT=8080

# Database
DATABASE_PATH=./data/hostbox.db
# Docker socket group on the host (needed for build containers in Docker installs)
DOCKER_GID=998

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Build containers (increase for large Node.js workspaces)
# BUILD_MEMORY_MB=1024
# BUILD_CPUS=1.0
# BUILD_PID_LIMIT=256

# Caddy
CADDY_ADMIN_URL=http://caddy:2019
ACME_EMAIL=admin@example.com

# DNS Provider for wildcard SSL (optional)
# Options: none, cloudflare, route53, digitalocean
# DNS_PROVIDER=
# CF_API_TOKEN=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_HOSTED_ZONE_ID=
# DO_AUTH_TOKEN=

# GitHub App (create at https://github.com/settings/apps)
# GITHUB_APP_ID=123456
# GITHUB_APP_SLUG=hostbox
# GITHUB_APP_PEM="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GITHUB_WEBHOOK_SECRET=generate-a-random-webhook-secret
