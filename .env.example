# Database
DATABASE_URL=postgres://hostbox:password@localhost:5432/hostbox

# Authentication (min 32 characters)
JWT_SECRET=change-this-to-a-random-secret-at-least-32-chars

# GitHub App (create at https://github.com/settings/apps)
GITHUB_APP_ID=123456
GITHUB_APP_SLUG=hostbox
# Generate with: openssl genpkey -algorithm RSA -out private-key.pem -pkeyopt rsa_keygen_bits:4096
GITHUB_APP_PEM="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"
GITHUB_WEBHOOK_SECRET=generate-a-random-webhook-secret

# Platform Configuration
PLATFORM_DOMAIN=hostbox.example.com
PLATFORM_HTTPS=true
PLATFORM_NAME=Hostbox

# Email (for sending verification emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=hostbox@example.com
SMTP_PASS=password
EMAIL_FROM=hostbox@example.com

# Logging
LOG_LEVEL=debug
